      <aliases enabled='yes' />
      <column caption='Age Difference' datatype='integer' name='[Age_Difference]' role='measure' type='quantitative' />
      <column caption='Resolution Rate' datatype='real' name='[Calculation_0289225089290240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Disposition] = &quot;CLOSED&quot; THEN 1 ELSE 0 END) / COUNT([Disposition])' />
      </column>
      <column caption='Open Cases' datatype='integer' name='[Calculation_0289225089417217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Disposition] = &quot;OPEN&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Closed Cases' datatype='integer' name='[Calculation_0289225089736706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Disposition] = &quot;CLOSED&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Same Gender %' datatype='real' name='[Calculation_0289225089863683]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Same_Gender]) / COUNT([Same_Gender])' />
      </column>
      <column caption='Same Race %' datatype='real' name='[Calculation_0289225089970180]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Same_Race]) / COUNT([Same_Race])' />
      </column>
      <column caption='Victim Count' datatype='integer' name='[Calculation_0289225094545415]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Victim_Age_Band])' />
      </column>
      <column caption='Offender Count' datatype='integer' name='[Calculation_0289225094631432]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='- COUNT([Offender_Age_Band])' />
      </column>
      <column caption='1' datatype='integer' name='[Calculation_0289225106079755]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
      <column caption='Count Fix' datatype='integer' name='[Calculation_2010512161251331]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(COUNT([Category]))' />
      </column>
      <column caption='Gender Combo' datatype='string' name='[Calculation_2010512167583748]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Offender_Gender] + &quot; → &quot; + [Victim_Gender]' />
      </column>
      <column caption='Category (copy)' datatype='string' name='[Category (copy)_2010511992123393]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Category]' />
      </column>
