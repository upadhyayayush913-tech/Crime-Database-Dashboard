              <calculation class='tableau' formula='-COUNT([Offender_Age_Band])' />
            </column>
            <column caption='age Band' datatype='string' name='[Calculation_1208968558018566]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF NOT ISNULL([Offender_Age]) THEN&#13;&#10;    IF [Offender_Age] &lt;= 17 THEN &quot;0–17&quot;&#13;&#10;    ELSEIF [Offender_Age] &lt;= 25 THEN &quot;18–25&quot;&#13;&#10;    ELSEIF [Offender_Age] &lt;= 35 THEN &quot;26–35&quot;&#13;&#10;    ELSEIF [Offender_Age] &lt;= 45 THEN &quot;36–45&quot;&#13;&#10;    ELSEIF [Offender_Age] &lt;= 60 THEN &quot;46–60&quot;&#13;&#10;    ELSE &quot;60+&quot;&#13;&#10;    END&#13;&#10;ELSE&#13;&#10;    IF [Victim_Age] &lt;= 17 THEN &quot;0–17&quot;&#13;&#10;    ELSEIF [Victim_Age] &lt;= 25 THEN &quot;18–25&quot;&#13;&#10;    ELSEIF [Victim_Age] &lt;= 35 THEN &quot;26–35&quot;&#13;&#10;    ELSEIF [Victim_Age] &lt;= 45 THEN &quot;36–45&quot;&#13;&#10;    ELSEIF [Victim_Age] &lt;= 60 THEN &quot;46–60&quot;&#13;&#10;    ELSE &quot;60+&quot;&#13;&#10;    END&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal'>
