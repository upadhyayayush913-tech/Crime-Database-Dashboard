    <worksheet name='OBJ 5  - Same vs Cross-Race Concentration'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#38bdf8'>OBJ 5  </run>
            <run bold='true' fontcolor='#666666'>- Same vs Cross-Race Concentration</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#ffffff'>% of Total Count of Category for each Category.  Color shows details about Race Type. The data is filtered on sum of Same Race, which includes everything.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='crime_data_cleaned (crime_data_cleaned)' name='federated.1ct35691nzrczl1dvcpxo1ohbglk' />
          </datasources>
          <datasource-dependencies datasource='federated.1ct35691nzrczl1dvcpxo1ohbglk'>
            <column caption='Race Type' datatype='string' name='[Calculation_1208968546885635]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Victim_Race] = [Offender_Race] THEN &quot;Same race&quot;&#13;&#10;ELSE &quot;Cross race&quot;&#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Drug and Weapon Crimes&quot;' value='Drug and weapons' />
              </aliases>
            </column>
            <column caption='Offender Race' datatype='string' name='[Offender_Race]' role='dimension' type='nominal' />
