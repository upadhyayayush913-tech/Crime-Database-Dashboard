    <worksheet name='OBJ2 - Case Resolution Rate per Category'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#38bdf8'>OBJ 2 </run>
            <run bold='true' fontcolor='#666666'>-</run>
            <run bold='true' fontcolor='#38bdf8'>Æ </run>
            <run bold='true' fontcolor='#666666'>Case Resolution Rate per Category</run>
            <run>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='crime_data_cleaned (crime_data_cleaned)' name='federated.1ct35691nzrczl1dvcpxo1ohbglk' />
          </datasources>
          <datasource-dependencies datasource='federated.1ct35691nzrczl1dvcpxo1ohbglk'>
            <column caption='Resolution Rate' datatype='real' name='[Calculation_0289225089290240]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Disposition] = &quot;CLOSED&quot; THEN 1 ELSE 0 END) / COUNT([Disposition])' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;Drug and Weapon Crimes&quot;' value='Drug and weapons' />
              </aliases>
            </column>
            <column datatype='string' name='[Disposition]' role='dimension' type='nominal' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Disposition]' derivation='None' name='[none:Disposition:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0289225089290240]' derivation='User' name='[usr:Calculation_0289225089290240:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1ct35691nzrczl1dvcpxo1ohbglk].[none:Category:nk]' filter-group='3'>
            <groupfilter function='level-members' level='[none:Category:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1ct35691nzrczl1dvcpxo1ohbglk].[none:Disposition:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:Disposition:nk]' member='&quot;CLOSED&quot;' />
              <groupfilter function='member' level='[none:Disposition:nk]' member='&quot;OPEN&quot;' />
            </groupfilter>
          </filter>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.1ct35691nzrczl1dvcpxo1ohbglk].[none:Category:nk]' direction='DESC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.1ct35691nzrczl1dvcpxo1ohbglk].[usr:Calculation_0289225089290240:qk]' shelf='rows' />
          </shelf-sorts>
          <slices>
            <column>[federated.1ct35691nzrczl1dvcpxo1ohbglk].[none:Category:nk]</column>
            <column>[federated.1ct35691nzrczl1dvcpxo1ohbglk].[none:Disposition:nk]</column>
          </slices>
          <aggregation value='true' />
